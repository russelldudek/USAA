%,100%{opacity:.45;transform:scaleY(.75)}50%{opacity:1;transform:scaleY(1)}}
.section{padding:6rem 1.25rem}.section-inner{max-width:1120px;margin:auto}.section-dark{background:#07213c;color:white}.section-mist{background:var(--mist)}.kicker{font-size:.76rem;font-weight:900;text-transform:uppercase;letter-spacing:.12em;color:var(--usaa-red);margin-bottom:.85rem}.section h2{font-family:var(--font-condensed);font-size:clamp(2.2rem,4vw,4.2rem);line-height:1;letter-spacing:-.035em;margin:0 0 1.2rem;color:var(--usaa-navy)}.section-dark h2{color:white}.section-intro{font-size:1.12rem;max-width:760px;color:var(--muted)}.section-dark .section-intro{color:#c9d9e6}.moment-grid{display:grid;grid-template-columns:.88fr 1.12fr;gap:5rem;align-items:start}.moment-stat{border-top:5px solid var(--usaa-gold);padding-top:1rem;margin-top:2rem}.moment-stat strong{font-family:var(--font-condensed);font-size:3.2rem;color:var(--usaa-navy);display:block}.pressure-list{counter-reset:p}.pressure-row{counter-increment:p;display:grid;grid-template-columns:56px 1fr 1fr;gap:1.5rem;padding:1.35rem 0;border-top:1px solid var(--line)}.pressure-row:before{content:"0" counter(p);font-family:var(--font-condensed);font-size:1.5rem;color:var(--usaa-red);font-weight:800}.pressure-row strong{font-size:1.04rem}.pressure-row p{margin:0;color:var(--muted)}
.model-layout{display:grid;grid-template-columns:300px 1fr;gap:3.5rem;margin-top:2.6rem}.scenario-panel{border-left:3px solid var(--usaa-red);padding-left:1.2rem}.scenario-panel h3{margin-top:0}.scenario-buttons{display:flex;flex-direction:column;gap:.55rem}.scenario-buttons button{font:inherit;text-align:left;border:1px solid #8ca7ba;background:transparent;color:white;padding:.75rem .8rem;cursor:pointer}.scenario-buttons button[aria-selected="true"]{background:white;color:var(--usaa-navy);font-weight:900;border-color:white}.scenario-buttons button:focus-visible{outline:3px solid var(--usaa-gold);outline-offset:2px}.model-stage{position:relative;min-height:450px}.model-stage .twin-shell{min-height:450px}.model-note{font-size:.76rem;color:#aac1d2;margin-top:.8rem}
.decision-table{width:100%;border-collapse:collapse;margin-top:2rem;background:white}.decision-table th,.decision-table td{padding:1rem .8rem;border-bottom:1px solid var(--line);vertical-align:top;text-align:left}.decision-table th{font-size:.74rem;text-transform:uppercase;letter-spacing:.07em;color:var(--usaa-blue)}.decision-table tr:last-child td{border-bottom:0}.decision-table strong{color:var(--usaa-navy)}.decision-tag{font-size:.73rem;font-weight:900;letter-spacing:.05em;text-transform:uppercase;color:var(--usaa-red)}
.score-line{display:grid;grid-template-columns:170px 1fr 1fr;padding:1.2rem 0;border-top:1px solid #adc2d2;gap:1.2rem}.score-line strong{color:var(--usaa-navy)}.score-line span{color:var(--muted)}.score-line em{font-style:normal;color:#315f80}
.proof-river{margin-top:2.4rem;position:relative}.proof-river:before{content:"";position:absolute;left:27%;top:0;bottom:0;width:2px;background:linear-gradient(var(--usaa-gold),var(--usaa-red))}.proof-row{display:grid;grid-template-columns:25% 8% 1fr;gap:1.2rem;align-items:start;padding:1.2rem 0}.proof-row .date{font-size:.8rem;color:#a8c0d2}.proof-row .marker{width:14px;height:14px;background:var(--usaa-gold);border-radius:50%;margin:.3rem auto;position:relative;z-index:1}.proof-row strong{display:block;color:white}.proof-row p{margin:.25rem 0 0;color:#c4d5e1}.proof-row small{color:#8fb4ca}.proof-row:nth-child(2) .marker{background:#7ec4d9}.proof-row:nth-child(3) .marker{background:var(--assurance-mint)}.proof-row:nth-child(4) .marker{background:var(--usaa-red)}
.plan-band{display:grid;grid-template-columns:repeat(4,1fr);margin-top:2.2rem;border-top:4px solid var(--usaa-navy)}.plan-phase{padding:1.2rem 1rem 1.7rem;border-right:1px solid var(--line)}.plan-phase:last-child{border-right:0}.plan-phase b{display:block;color:var(--usaa-red);font-size:.75rem;text-transform:uppercase;letter-spacing:.08em}.plan-phase h3{color:var(--usaa-navy);margin:.4rem 0}.plan-phase p{color:var(--muted);font-size:.9rem}.objection-wrap{display:grid;grid-template-columns:.85fr 1.15fr;gap:4rem;align-items:start}.objection-question{font-family:var(--font-condensed);font-size:2.4rem;line-height:1.05;color:var(--usaa-gold)}.objection-answer{border-top:1px solid #5f7991;padding-top:1rem}.objection-answer h3{margin:0;color:white}.objection-answer p{color:#cbd9e4}.question-list{columns:2;column-gap:4rem;margin-top:2rem}.question{break-inside:avoid;border-top:2px solid var(--usaa-navy);padding:1rem 0 1.4rem}.question span{color:var(--usaa-red);font-size:.76rem;font-weight:900}.question p{font-weight:800;color:var(--usaa-navy);margin:.25rem 0}.docs-strip{display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;margin-top:2rem}.doc-link{text-decoration:none;border:1px solid #87a4b9;padding:1.2rem;background:white;min-height:140px;transition:transform .2s,box-shadow .2s}.doc-link:hover,.doc-link:focus-visible{transform:translateY(-3px);box-shadow:var(--shadow)}.doc-link strong{display:block;color:var(--usaa-navy)}.doc-link small{color:var(--muted)}.sources{font-size:.8rem;color:#617487}.sources li{margin:.45rem 0}.site-footer{background:#001f3e;color:#bcd0df;padding:2.5rem 1.25rem}.footer-inner{max-width:1120px;margin:auto;display:flex;justify-content:space-between;gap:2rem}.site-footer a{color:white}
/* Document system */
.doc-body{background:#dbe5ec}.doc-toolbar{position:sticky;top:0;z-index:50;background:#092a4a;color:white;padding:.7rem 1rem;display:flex;justify-content:center;gap:.7rem;flex-wrap:wrap}.doc-toolbar a,.doc-toolbar button{font:inherit;text-decoration:none;border:1px solid rgba(255,255,255,.45);background:transparent;color:white;padding:.5rem .7rem;cursor:pointer}.doc-toolbar .primary{background:white;color:var(--usaa-navy);font-weight:800}.document{max-width:8.5in;margin:1.25rem auto}.paper{width:8.5in;min-height:11in;background:white;margin:0 auto 1.2rem;box-shadow:0 12px 40px r