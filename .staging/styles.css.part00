@import url("brand-tokens.css");
*{box-sizing:border-box}html{scroll-behavior:smooth}body{margin:0;font-family:var(--font-sans);color:var(--ink);background:var(--paper);line-height:1.55}a{color:inherit}img{max-width:100%;height:auto}.skip{position:absolute;left:-999px}.skip:focus{left:1rem;top:1rem;background:#fff;padding:.65rem 1rem;z-index:999}
.site-header{position:sticky;top:0;z-index:50;background:rgba(255,255,255,.96);backdrop-filter:blur(10px);border-bottom:1px solid rgba(0,45,90,.12)}.nav{max-width:1180px;margin:auto;display:flex;align-items:center;justify-content:space-between;padding:.75rem 1.25rem}.candidate-id{font-weight:800;letter-spacing:.01em;color:var(--usaa-navy)}.nav-links{display:flex;gap:1rem;align-items:center}.nav-links a{text-decoration:none;font-size:.86rem;font-weight:700;color:#31516d}.nav-links a:hover,.nav-links a:focus-visible{color:var(--usaa-blue)}.nav-links .nav-primary{background:var(--usaa-navy);color:white;padding:.65rem .9rem;border-radius:3px}.menu-btn{display:none;border:0;background:transparent;font-size:1.4rem;color:var(--usaa-navy)}
.hero{background:var(--usaa-navy);color:white;min-height:720px;position:relative;overflow:hidden}.hero:before{content:"";position:absolute;inset:-22% -5% auto auto;width:55%;height:80%;background:radial-gradient(circle,rgba(120,184,216,.25),transparent 68%);pointer-events:none}.hero-inner{max-width:1180px;margin:auto;padding:3.1rem 1.25rem 4rem}.employer-lockup{display:flex;align-items:center;gap:1rem;margin-bottom:2.2rem}.employer-lockup img{width:132px;display:block}.employer-copy{border-left:1px solid rgba(255,255,255,.32);padding-left:1rem;font-size:.85rem;letter-spacing:.06em;text-transform:uppercase}.employer-copy strong{display:block;font-size:.95rem;letter-spacing:.02em;text-transform:none}.hero-grid{display:grid;grid-template-columns:minmax(0,.95fr) minmax(500px,1.05fr);gap:4.5rem;align-items:center}.hero h1{font-family:var(--font-condensed);font-size:clamp(3.3rem,6vw,6.1rem);line-height:.92;letter-spacing:-.045em;margin:0 0 1.45rem;max-width:720px}.hero h1 span{color:var(--usaa-gold)}.hero-lead{font-size:1.18rem;max-width:610px;color:#dbeaf4}.hero-proof{display:flex;gap:1.1rem;flex-wrap:wrap;margin-top:1.6rem}.hero-proof span{border-top:2px solid var(--usaa-red);padding-top:.45rem;font-size:.78rem;text-transform:uppercase;letter-spacing:.06em;color:#dce8f2}.hero-action{display:inline-flex;margin-top:1.6rem;text-decoration:none;background:#fff;color:var(--usaa-navy);font-weight:800;padding:.85rem 1.1rem;border-radius:3px}
.twin-shell{position:relative;background:linear-gradient(145deg,rgba(255,255,255,.08),rgba(255,255,255,.025));border:1px solid rgba(255,255,255,.18);padding:1.25rem 1.25rem 1.4rem;min-height:470px;box-shadow:0 30px 80px rgba(0,0,0,.2)}.twin-title{display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem;font-size:.78rem;text-transform:uppercase;letter-spacing:.08em;color:#cce0ee}.decision-chip{background:var(--usaa-gold);color:#152d45;padding:.35rem .55rem;font-weight:900;letter-spacing:.02em}.twin-plane{position:relative;border:1px solid rgba(255,255,255,.2);padding:1rem 1rem 1.2rem;margin:.8rem 0;background:rgba(0,20,42,.25)}.twin-plane h3{margin:0 0 .8rem;font-size:.85rem;letter-spacing:.08em;text-transform:uppercase}.plane-track{height:72px;display:grid;grid-template-columns:repeat(4,1fr);gap:.55rem;position:relative}.plane-stage{border-left:2px solid rgba(255,255,255,.32);padding-left:.55rem;font-size:.74rem;color:#d6e3ec;display:flex;align-items:flex-end;position:relative}.plane-stage:before{content:"";position:absolute;top:9px;left:-6px;width:10px;height:10px;border-radius:50%;background:#fff}.work-plane .plane-stage:before{background:var(--usaa-gold)}.assurance-plane .plane-stage:before{background:var(--assurance-mint)}.track-signal{position:absolute;left:0;top:20px;width:30%;height:10px;background:linear-gradient(90deg,transparent,var(--usaa-gold),transparent);filter:drop-shadow(0 0 6px rgba(233,183,47,.8));animation:signal-run 4.8s linear infinite}.assurance-plane .track-signal{background:linear-gradient(90deg,transparent,var(--assurance-mint),transparent);filter:drop-shadow(0 0 6px rgba(127,210,193,.8));animation-delay:.12s}.twin-links{position:absolute;left:1.25rem;right:1.25rem;top:152px;height:137px;pointer-events:none}.twin-links i{position:absolute;width:1px;background:rgba(127,210,193,.45);top:0;bottom:0;animation:link-pulse 2.8s ease-in-out infinite}.twin-links i:nth-child(1){left:13%}.twin-links i:nth-child(2){left:38%;animation-delay:.2s}.twin-links i:nth-child(3){left:63%;animation-delay:.4s}.twin-links i:nth-child(4){left:88%;animation-delay:.6s}.twin-readout{display:grid;grid-template-columns:1.2fr .8fr;gap:.8rem;margin-top:1rem}.readout-copy{border-top:1px solid rgba(255,255,255,.2);padding-top:.8rem}.readout-copy strong{display:block;font-size:1.05rem}.readout-copy span{display:block;font-size:.78rem;color:#c9dbe8;margin-top:.3rem}.sync-meter{display:flex;align-items:flex-end;gap:.3rem;justify-content:flex-end}.sync-meter i{width:12px;background:var(--assurance-mint);height:22px;animation:meter 1.8s ease-in-out infinite}.sync-meter i:nth-child(2){height:35px;animation-delay:.15s}.sync-meter i:nth-child(3){height:48px;animation-delay:.3s}.sync-meter i:nth-child(4){height:61px;animation-delay:.45s}.twin-shell.is-lagging .assurance-plane .track-signal{animation-duration:7.8s;opacity:.5}.twin-shell.is-lagging .twin-links i:nth-child(3),.twin-shell.is-lagging .twin-links i:nth-child(4){background:var(--usaa-red);opacity:.45}.twin-shell.is-hold .track-signal{animation-play-state:paused;opacity:.25}.twin-shell.is-human .work-plane .track-signal{width:18%;animation-duration:6.6s}.twin-shell.is-human .plane-stage:nth-child(3):before{transform:scale(1.6);box-shadow:0 0 0 6px rgba(233,183,47,.15)}
@keyframes signal-run{from{transform:translateX(-55%)}to{transform:translateX(330%)}}@keyframes link-pulse{0%,100%{opacity:.25}50%{opacity:1}}@keyframes meter{0